{
  "$meta": {
    "name": "METI Design Tokens",
    "version": "1.0.0",
    "description": "디지털 명함 네트워킹 플랫폼 METI 의 브랜드/UI 컬러 및 디자인 토큰. 메인 컬러는 진한 잉크 네이비이며, 골드(샴페인)를 악센트로 사용한다.",
    "updated": "2026-06-14"
  },

  "brand": {
    "navy":      { "value": "#0B1E40", "oklch": "oklch(0.27 0.07 262)", "desc": "메인 컬러. 명함 본체·핵심 UI·강조" },
    "navyDeep":  { "value": "#06122A", "desc": "명함 그라데이션 하단/그림자" },
    "navyGlow":  { "value": "#1C3D72", "desc": "명함 상단 광택 하이라이트" },
    "gold":      { "value": "#C9A86A", "oklch": "oklch(0.76 0.095 85)", "desc": "기본 악센트(앱). 금박 명함 질감" },
    "goldDeep":  { "value": "#9A7333", "desc": "골드 그라데이션/텍스트 대비" },
    "goldAdmin": { "value": "#C2974E", "desc": "어드민용 골드(밝은 배경에서 가독성 보정)" }
  },

  "accentOptions": {
    "$desc": "악센트 대체 옵션. 동일 채도·명도, 색상(hue)만 변경. 기본은 gold.",
    "gold":   "oklch(0.76 0.095 85)",
    "mint":   "oklch(0.74 0.095 168)",
    "coral":  "oklch(0.72 0.12 33)",
    "violet": "oklch(0.66 0.13 290)"
  },

  "cardFinish": {
    "$desc": "디지털 명함 표면 마감재. base→deep 라디얼 그라데이션 + glow 하이라이트.",
    "navy":     { "base": "#0B1E40", "deep": "#06122A", "glow": "#1C3D72" },
    "midnight": { "base": "#14161C", "deep": "#070809", "glow": "#2A2E38" },
    "teal":     { "base": "#06303A", "deep": "#021C23", "glow": "#0C5163" }
  },

  "semantic": {
    "light": {
      "bg":       "#F4F5F8",
      "surface":  "#FFFFFF",
      "surface2": "#F7F8FA",
      "ink":      "#0E1726",
      "sub":      "#5B6577",
      "mute":     "#8B95A6",
      "line":     "rgba(14,23,38,0.08)",
      "line2":    "rgba(14,23,38,0.05)"
    },
    "dark": {
      "bg":       "#0C0F16",
      "surface":  "#161A23",
      "surface2": "#1E232E",
      "ink":      "#F2F4F8",
      "sub":      "#A7B0C0",
      "mute":     "#727C8C",
      "line":     "rgba(255,255,255,0.09)",
      "line2":    "rgba(255,255,255,0.06)"
    }
  },

  "status": {
    "success": { "fg": "#1B9C73", "soft": "rgba(27,156,115,0.12)" },
    "danger":  { "fg": "#D8513C", "soft": "rgba(216,81,60,0.12)" },
    "warn":    { "fg": "#C98A1E", "soft": "rgba(201,138,30,0.13)" },
    "info":    { "fg": "#3470C4", "soft": "rgba(52,112,196,0.12)" }
  },

  "typography": {
    "fontFamily": "Pretendard, -apple-system, system-ui, sans-serif",
    "fallbackCdn": "https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css",
    "weights": { "regular": 400, "medium": 500, "semibold": 600, "bold": 700, "extrabold": 800 },
    "scale": {
      "display":  { "size": 30, "weight": 700, "tracking": "-0.02em", "desc": "명함 이름/대형 타이틀" },
      "title":    { "size": 26, "weight": 800, "tracking": "-0.02em" },
      "heading":  { "size": 19, "weight": 700, "tracking": "-0.01em" },
      "body":     { "size": 15, "weight": 500 },
      "label":    { "size": 13, "weight": 600 },
      "caption":  { "size": 12, "weight": 600 }
    },
    "wordmark": { "$desc": "MET + 골드 I. 대문자, 자간 0.18~0.22em.", "tracking": "0.18em" }
  },

  "radius": { "sm": 8, "md": 14, "lg": 18, "card": 22, "pill": 9999 },

  "spacing": { "1": 4, "2": 8, "3": 12, "4": 16, "5": 20, "6": 24, "8": 32 },

  "elevation": {
    "card":   "0 1px 2px rgba(14,23,38,0.04), 0 8px 24px rgba(14,23,38,0.04)",
    "raised": "0 2px 4px rgba(6,18,42,0.25), 0 18px 40px -12px rgba(6,18,42,0.55)"
  }
}
