{
  "name": "meti-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:sandbox": "wrangler pages dev dist --d1=meti-production --local --ip 0.0.0.0 --port 3000",
    "css": "tailwindcss -c tailwind.config.js -i src/tailwind-input.css -o public/static/tailwind.css --minify",
    "build": "npm run css && vite build",
    "preview": "wrangler pages dev dist --d1=meti-production --local",
    "deploy": "npm run build && wrangler pages deploy dist --project-name the-meti --branch=main",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:create": "wrangler d1 create meti-production",
    "db:migrate:local": "wrangler d1 migrations apply meti-production --local",
    "db:migrate:prod": "wrangler d1 migrations apply meti-production",
    "db:seed": "wrangler d1 execute meti-production --local --file=./seed.sql",
    "db:reset": "rm -rf .wrangler/state/v3/d1 && npm run db:migrate:local && npm run db:seed",
    "db:console:local": "wrangler d1 execute meti-production --local",
    "db:console:prod": "wrangler d1 execute meti-production",
    "git:status": "git status",
    "git:commit": "git add . && git commit -m",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "test:setup": "CI=true npx playwright test --project=setup --timeout=60000",
    "test:run": "CI=true npx playwright test --project=chromium --timeout=60000",
    "test:all": "CI=true npm test -- --timeout=60000"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "bcryptjs": "^2.4.3",
    "hono": "^4.12.12",
    "jose": "^5.10.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260426.1",
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-cloudflare-pages": "^0.4.3",
    "@hono/vite-dev-server": "^0.18.2",
    "@playwright/test": "^1.59.1",
    "@types/bcryptjs": "^2.4.6",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.7.3",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
